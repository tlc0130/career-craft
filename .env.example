# ============================================================
# CareerCraft — environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_DB in docker-compose.yml
POSTGRES_PASSWORD=change_me_strong_password
# Automatically constructed by docker-compose; set this if running the API
# server outside Docker:
# DATABASE_URL=postgres://careercraft:<POSTGRES_PASSWORD>@localhost:5432/careercraft

# ── Session ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_32_char_random_string

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of fully-qualified origins that are allowed to call the API
ALLOWED_ORIGINS=https://craft.hiddentechdaily.com

# ── App URL (used in OpenRouter HTTP-Referer header) ─────────
APP_URL=https://craft.hiddentechdaily.com

# ── OpenRouter AI ────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: override the default model (must be available on your OpenRouter account)
# Cheap & capable defaults:
#   openai/gpt-4o-mini       — fast, cheap, JSON-mode support (default)
#   anthropic/claude-haiku-4 — very cheap
#   google/gemini-flash-1.5  — fast & cheap
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Stripe (optional — leave blank to disable payments) ──────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_LIFETIME_PRICE_ID=price_...

# ── AI credit limits ─────────────────────────────────────────
# Free-tier users get this many AI generations per month.
# Raised from 3 to 5 to give new users a better first-run experience.
STARTER_MONTHLY_AI_LIMIT=5

# ── Google OAuth (optional — leave blank to disable Google login) ────
# Get credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
# → Create OAuth 2.0 Client ID (Web application type).
# Set Authorized redirect URI to: https://craft.hiddentechdaily.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
